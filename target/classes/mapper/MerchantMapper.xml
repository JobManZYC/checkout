<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.saoma.pos.mapper.MerchantMapper">

    <resultMap id="MerchantResultMap" type="com.saoma.pos.entity.Merchant">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="contactName" column="contact_name"/>
        <result property="contactPhone" column="contact_phone"/>
        <result property="address" column="address"/>
        <result property="remark" column="remark"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findAll" resultMap="MerchantResultMap">
        SELECT * FROM merchant ORDER BY id DESC
    </select>

    <select id="findById" resultMap="MerchantResultMap" parameterType="long">
        SELECT * FROM merchant WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.saoma.pos.entity.Merchant" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO merchant(name, contact_name, contact_phone, address, remark, status, create_time, update_time)
        VALUES(#{name}, #{contactName}, #{contactPhone}, #{address}, #{remark}, #{status}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.saoma.pos.entity.Merchant">
        UPDATE merchant
        SET name = #{name},
            contact_name = #{contactName},
            contact_phone = #{contactPhone},
            address = #{address},
            remark = #{remark},
            status = #{status},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM merchant WHERE id = #{id}
    </delete>

</mapper>
