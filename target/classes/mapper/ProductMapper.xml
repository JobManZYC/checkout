<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.saoma.pos.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="com.saoma.pos.entity.Product">
        <id property="id" column="id"/>
        <result property="merchantId" column="merchant_id"/>
        <result property="barcode" column="barcode"/>
        <result property="name" column="name"/>
        <result property="category" column="category"/>
        <result property="price" column="price"/>
        <result property="cost" column="cost"/>
        <result property="stock" column="stock"/>
        <result property="unit" column="unit"/>
        <result property="remark" column="remark"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findByBarcode" resultMap="ProductResultMap">
        SELECT * FROM product WHERE barcode = #{barcode} LIMIT 1
    </select>

    <select id="findByMerchantAndBarcode" resultMap="ProductResultMap">
        SELECT * FROM product WHERE merchant_id = #{merchantId} AND barcode = #{barcode} LIMIT 1
    </select>

    <update id="decreaseStock">
        UPDATE product SET stock = stock - #{quantity} WHERE id = #{id}
    </update>

    <update id="increaseStock">
        UPDATE product SET stock = stock + #{quantity} WHERE id = #{id}
    </update>

    <select id="findAllCategories" resultType="string">
        SELECT DISTINCT category FROM product WHERE category IS NOT NULL AND category != '' ORDER BY category
    </select>

    <select id="findCategoriesByMerchantId" resultType="string">
        SELECT DISTINCT category FROM product WHERE merchant_id = #{merchantId} AND category IS NOT NULL AND category != '' ORDER BY category
    </select>

</mapper>
